{
  "manifest_version": 3,
  "name": "Personal Jobs Assistant",
  "version": "1.0.0",
  "description": "Automate job tracking, resume tailoring, and application filling via local AI.",
  "permissions": [
    "activeTab",       
    "storage",         
    "sidePanel",       
    "scripting",       
    "identity",
    "unlimitedStorage" 
  ],
  "web_accessible_resources": [
    {
      "resources": ["*.js", "*.wasm", "*.onnx"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "host_permissions": [
    "https://www.googleapis.com/*",
    "http://localhost:11434/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"], 
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "oauth2": {
    "client_id": "1077531793820-1odn89hneuvvva42kncs124f3e7qf574.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "action": {
    "default_icon": {
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "128": "icons/icon-128.png"
  }
}